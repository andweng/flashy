# SPA fallback for dynamic deck routes (/decks/<id>).
# Targets app.html (a build-time copy of index.html) instead of index.html
# directly so Cloudflare Pages' redirect-loop analyzer doesn't trip on the
# /index path-normalization heuristic. Static files (e.g. /home.html,
# /decks/new.html, /sw.js) are still served as-is — Cloudflare Pages checks
# for existing files before evaluating redirect rules.
/decks/*    /app.html   200

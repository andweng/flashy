# Copy to .env.local (gitignored). Expo loads EXPO_PUBLIC_* vars into the client bundle.

# Default true while we develop against fixtures.
# Set to false to point the app at your Supabase project.
EXPO_PUBLIC_USE_MOCK=true

# From Supabase dashboard → Settings → API.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
